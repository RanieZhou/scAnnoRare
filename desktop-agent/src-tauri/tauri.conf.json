{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scAnnoRare Agent",
  "version": "1.0.0",
  "identifier": "com.scannorare.agent",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "scAnnoRare Local Agent",
        "width": 480,
        "height": 560,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../local-agent/packaging/dist/scannorare-agent": "agent"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
